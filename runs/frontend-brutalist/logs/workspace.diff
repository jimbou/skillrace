+@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Anton&family=Inter:wght@300;900&display=swap');
+*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
+:root{--void:#0a0a0a;--acid:#c8ff00;--blood:#ff1a5f;--ice:#00f0ff;--bone:#f0ece2;--rot:#b534f2;--smoke:#1a1a1a}
+html,body{scrollbar-width:thin;scrollbar-color:var(--acid) var(--void)}
+body{background:var(--void);color:var(--bone);font-family:'Inter',sans-serif;overflow-x:hidden;cursor:crosshair}
+::selection{background:var(--acid);color:var(--void)}
+@keyframes gc{0%,100%{clip-path:inset(0 0 95% 0);transform:translate(-2px,2px)}10%{clip-path:inset(20% 0 60% 0);transform:translate(2px,-1px)}25%{clip-path:inset(50% 0 30% 0);transform:translate(-1px,3px)}40%{clip-path:inset(70% 0 5% 0);transform:translate(3px,0)}55%{clip-path:inset(40% 0 40% 0);transform:translate(1px,-2px)}70%{clip-path:inset(60% 0 20% 0);transform:translate(-2px,0)}85%{clip-path:inset(5% 0 70% 0);transform:translate(2px,2px)}}
+@keyframes gm{0%,100%{clip-path:inset(95% 0 0 0);transform:translate(2px,-2px)}15%{clip-path:inset(60% 0 20% 0);transform:translate(-3px,1px)}30%{clip-path:inset(80% 0 5% 0);transform:translate(1px,-3px)}45%{clip-path:inset(30% 0 50% 0);transform:translate(-2px,2px)}60%{clip-path:inset(50% 0 30% 0);transform:translate(3px,0)}75%{clip-path:inset(15% 0 70% 0);transform:translate(-1px,-2px)}90%{clip-path:inset(40% 0 40% 0);transform:translate(2px,1px)}}
+@keyframes fl{0%,100%{opacity:1}41%{opacity:1}42%{opacity:0.7}43%{opacity:1}45%{opacity:0.3}46%{opacity:1}51%{opacity:0.6}52%{opacity:1}93%{opacity:0.5}94%{opacity:1}}
+@keyframes sm{0%{transform:translateY(-100%)}100%{transform:translateY(100vh)}}
+@keyframes mq{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
+@keyframes rs{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
+@keyframes ns{0%,100%{background-position:0 0}25%{background-position:50% 50%}50%{background-position:-25% 75%}75%{background-position:75% 25%}}
+.scanline-overlay{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.03) 2px,rgba(0,0,0,0.03) 4px)}
+.scanline-overlay::after{content:'';position:absolute;top:0;left:0;width:100%;height:8px;background:linear-gradient(to bottom,transparent,rgba(200,255,0,0.04),transparent);animation:sm 4s linear infinite}
+.noise-bg{position:fixed;top:-50%;left:-50%;width:200%;height:200%;z-index:-1;opacity:0.035;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");animation:ns 0.5s steps(10) infinite}
+nav{position:fixed;top:2rem;right:2rem;z-index:1000;mix-blend-mode:difference}
+nav ul{list-style:none;display:flex;gap:0}
+nav a{font-family:'Space Mono',monospace;font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--bone);text-decoration:none;padding:0.6rem 1.4rem;display:block;transition:all 0.3s;position:relative}
+nav a::before{content:'//';margin-right:0.4rem;color:var(--acid);opacity:0;transition:opacity 0.2s}
+nav a:hover::before{opacity:1}
+nav a:hover{color:var(--acid);background:rgba(200,255,0,0.05)}
+.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr 1fr;grid-template-rows:auto auto auto;position:relative;overflow:hidden}
+.hdb{grid-column:1/3;grid-row:1;padding:8vh 5vw 0 3vw;position:relative}
+.hds{font-family:'Space Mono',monospace;font-size:clamp(0.55rem,0.9vw,0.8rem);letter-spacing:0.5em;text-transform:uppercase;color:var(--acid);margin-bottom:1.5rem;display:inline-block;border-left:3px solid var(--acid);padding-left:1.2rem;animation:fl 8s infinite}
+.ht{font-family:'Anton',sans-serif;font-size:clamp(4rem,15vw,14rem);line-height:0.85;text-transform:uppercase;letter-spacing:-0.03em;color:var(--bone);position:relative}
+.ht .gl{position:absolute;top:0;left:0;width:100%;height:100%}
+.ht .lc{color:var(--ice);animation:gc 3s infinite linear alternate-reverse;z-index:1}
+.ht .lm{color:var(--blood);animation:gm 2.5s infinite linear alternate-reverse;z-index:1}
+.ht .ml{z-index:2}
+.hs{font-weight:300;font-size:clamp(0.85rem,1.8vw,1.3rem);letter-spacing:0.15em;text-transform:uppercase;color:rgba(240,236,226,0.35);margin-top:1.5rem;max-width:40ch}
+.hv{grid-column:3;grid-row:1/3;position:relative;overflow:hidden}
+.hv::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--acid) 0%,transparent 40%),linear-gradient(225deg,var(--blood) 0%,transparent 40%);opacity:0.25;z-index:2}
+.hvi{width:100%;height:100%;min-height:60vh;background:linear-gradient(45deg,var(--smoke) 25%,transparent 25%),linear-gradient(-45deg,var(--smoke) 25%,transparent 25%),linear-gradient(45deg,transparent 75%,var(--smoke) 75%),linear-gradient(-45deg,transparent 75%,var(--smoke) 75%);background-size:20px 20px;background-position:0 0,0 10px,10px -10px,-10px 0;opacity:0.5;display:flex;align-items:center;justify-content:center}
+.hvsym{font-size:12rem;font-family:'Anton',sans-serif;color:var(--void);opacity:0.15;animation:rs 20s linear infinite}
+.hiside{grid-column:3;grid-row:3;padding:2rem 1rem;margin-top:-2vh}
+.hiside .stag{writing-mode:vertical-rl;text-orientation:mixed;font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.4em;text-transform:uppercase;color:rgba(200,255,0,0.3);padding-right:1rem;border-right:1px solid rgba(200,255,0,0.15)}
+.ddiv{position:absolute;top:0;right:30%;width:2px;height:100%;background:linear-gradient(to bottom,transparent,var(--acid),var(--blood),transparent);transform:skewX(-12deg);opacity:0.3;z-index:3}
+.ddiv:nth-of-type(2){right:32%;transform:skewX(-12deg) scaleX(0.5);opacity:0.15;background:linear-gradient(to bottom,transparent,var(--ice),transparent)}
+.cblock{position:absolute;bottom:3vh;left:5vw;font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.15em;color:rgba(240,236,226,0.18);line-height:2;z-index:5}
+.mstrip{background:var(--acid);color:var(--void);padding:0.8rem 0;overflow:hidden;white-space:nowrap;transform:rotate(-1.5deg) scale(1.03);margin:4rem -2vw;z-index:10;font-family:'Space Mono',monospace;font-weight:700;font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase}
+.mstrip::before,.mstrip::after{content:'';position:absolute;top:0;width:15vw;height:100%;z-index:2}
+.mstrip::before{left:0;background:linear-gradient(to right,var(--void),transparent)}
+.mstrip::after{right:0;background:linear-gradient(to left,var(--void),transparent)}
+.mccont{display:inline-block;animation:mq 20s linear infinite}
+.mccont span{margin-right:3rem}
+.sepb{color:var(--blood);font-size:1.2rem;margin:0 1rem}
+.lsec{padding:12vh 5vw;position:relative}
+.slabel{font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.5em;text-transform:uppercase;color:var(--acid);margin-bottom:4rem;display:flex;align-items:center;gap:1.5rem}
+.slabel::before{content:'';width:40px;height:1px;background:var(--acid)}
+.snbr{font-family:'Anton',sans-serif;font-size:clamp(3rem,8vw,7rem);line-height:1;color:transparent;-webkit-text-stroke:1px rgba(200,255,0,0.12);margin-bottom:2rem;text-transform:uppercase}
+.lgrid{display:flex;flex-direction:column;gap:0}
+.arow{display:grid;grid-template-columns:120px 1fr auto;align-items:baseline;padding:3rem 0;border-bottom:1px solid rgba(240,236,226,0.06);position:relative;transition:all 0.4s cubic-bezier(0.23,1,0.32,1);cursor:default}
+.arow:hover{padding-left:2rem;border-bottom-color:var(--acid)}
+.arow.feat{grid-template-columns:120px 1fr;padding:5rem 0;border-bottom:none}
+.arow.feat::after{content:'';position:absolute;left:0;bottom:0;width:60px;height:4px;background:var(--blood)}
+.arow.mh{grid-template-columns:100px 1fr auto;padding:6rem 0;border-bottom:none}
+.arow.mh:hover{padding-left:3rem}
