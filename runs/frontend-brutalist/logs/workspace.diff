+<script>
+// Glitch trigger on mouse movement near hero title
+var heroTitle = document.querySelector('.ht');
+if (heroTitle) {
+  heroTitle.addEventListener('mouseenter', function() {
+    var layers = heroTitle.querySelectorAll('.gl');
+    layers.forEach(function(l) { l.style.animationDuration = '0.3s'; });
+    setTimeout(function() {
+      layers.forEach(function(l) { l.style.animationDuration = ''; });
+    }, 500);
+  });
+}
+
+// Smooth scroll for anchor links
+document.querySelectorAll('a[href^="#"]').forEach(function(a) {
+  a.addEventListener('click', function(e) {
+    e.preventDefault();
+    var target = document.querySelector(a.getAttribute('href'));
+    if (target) target.scrollIntoView({ behavior: 'smooth' });
+  });
+});
+
+// Parallax on scroll for diagonal dividers
+var ticking = false;
+window.addEventListener('scroll', function() {
+  if (!ticking) {
+    requestAnimationFrame(function() {
+      var scrolled = window.pageYOffset;
+      var dds = document.querySelectorAll('.ddiv');
+      dds.forEach(function(dd) {
+        var newDeg = -12 + scrolled * 0.02;
+        dd.style.transform = 'skewX(' + newDeg + 'deg)';
+      });
+      ticking = false;
+    });
+    ticking = true;
+  }
+});
+
+// Random glitch bursts on artist names
+var arows = document.querySelectorAll('.arow');
+arows.forEach(function(row) {
+  row.addEventListener('mouseenter', function() {
+    var aname = row.querySelector('.aname');
+    if (aname) {
+      var orig = aname.textContent;
+      var chars = '!@#$%^&*<>?/\\|~`{}[]';
+      for (var i = 0; i < 5; i++) {
+        (function(idx) {
+          setTimeout(function() {
+            var scrambled = orig.split('').map(function(c) {
+              return Math.random() > 0.6 ? chars[Math.floor(Math.random() * chars.length)] : c;
+            }).join('');
+            aname.textContent = scrambled;
+            setTimeout(function() { aname.textContent = orig; }, 150);
+          }, idx * 60);
+        })(i);
+      }
+    }
+  });
+});
+</script>
