+.insec{padding:12vh 5vw}
+.igrd{display:flex;flex-direction:column;gap:0}
+.icard{position:relative;padding:4rem 3rem;border:1px solid rgba(240,236,226,0.06);transition:all 0.5s cubic-bezier(0.23,1,0.32,1);overflow:hidden}
+.icard::before{content:'';position:absolute;top:0;left:0;width:4px;height:0;transition:height 0.5s cubic-bezier(0.23,1,0.32,1)}
+.icard:nth-child(1)::before{background:var(--acid)}
+.icard:nth-child(2)::before{background:var(--blood)}
+.icard:nth-child(3)::before{background:var(--ice)}
+.icard:hover::before{height:100%}
+.icard:hover{transform:translateX(1rem) skewX(-1deg);border-color:rgba(240,236,226,0.12);background:rgba(200,255,0,0.01)}
+.icard:nth-child(2){margin-left:8vw}
+.icard:nth-child(3){margin-left:-4vw}
+.icnum{font-family:'Anton',sans-serif;font-size:5rem;line-height:1;color:transparent;-webkit-text-stroke:1px rgba(240,236,226,0.07);position:absolute;top:1rem;right:2rem}
+.icicon{font-size:1.5rem;margin-bottom:1.5rem;display:inline-block}
+.iCTitle{font-family:'Anton',sans-serif;font-size:clamp(1.5rem,3vw,2.5rem);text-transform:uppercase;letter-spacing:-0.01em;margin-bottom:1rem}
+.iCtxt{font-weight:300;font-size:0.9rem;line-height:1.8;color:rgba(240,236,226,0.45);max-width:35ch}
+.ctasection{position:relative;padding:15vh 5vw;display:flex;flex-direction:column;align-items:flex-start;overflow:hidden}
+.ctasection::before{content:'';position:absolute;top:0;right:0;width:50%;height:100%;background:var(--blood);clip-path:polygon(30% 0,100% 0,100% 100%,0 100%);opacity:0.07}
+.ctatext{font-family:'Anton',sans-serif;font-size:clamp(4rem,12vw,12rem);line-height:0.9;text-transform:uppercase;letter-spacing:-0.04em;position:relative;z-index:2}
+.ctatext .hl{color:var(--acid);display:inline-block;position:relative}
+.ctatext .hl::after{content:'';position:absolute;bottom:0.1em;left:0;width:100%;height:0.15em;background:var(--acid);transform:scaleX(0);transform-origin:right;transition:transform 0.6s cubic-bezier(0.23,1,0.32,1)}
+.ctatext .hl:hover::after{transform:scaleX(1);transform-origin:left}
+.ctasub{font-family:'Space Mono',monospace;font-size:0.7rem;letter-spacing:0.3em;text-transform:uppercase;color:rgba(240,236,226,0.25);margin-top:3rem;position:relative;z-index:2;margin-left:0.1em}
+.actbtn{display:inline-flex;align-items:center;gap:1.5rem;margin-top:4rem;position:relative;z-index:2;font-family:'Space Mono',monospace;font-size:0.8rem;letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;color:var(--void);background:var(--acid);padding:1.2rem 3rem;border:none;cursor:pointer;transition:all 0.4s cubic-bezier(0.23,1,0.32,1);clip-path:polygon(0 0,calc(100% - 1rem) 0,100% 1rem,100% 100%,1rem 100%,0 calc(100% - 1rem))}
+.actbtn:hover{background:var(--bone);transform:translateX(0.5rem) translateY(-0.2rem);box-shadow:8px 8px 0 var(--blood)}
+.actbtn .arr{transition:transform 0.3s}
+.actbtn:hover .arr{transform:translateX(0.5rem)}
+.ctacorner{font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:0.2em;color:rgba(240,236,226,0.15);margin-top:2rem;position:relative;z-index:2}
+.footer{padding:6vh 5vw;border-top:1px solid rgba(240,236,226,0.06);display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:2rem}
+.fbrand{font-family:'Anton',sans-serif;font-size:1.2rem;text-transform:uppercase;letter-spacing:0.05em}
+.flinks{display:flex;gap:2rem}
+.flinks a{font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(240,236,226,0.3);text-decoration:none;transition:color 0.3s}
+.flinks a:hover{color:var(--acid)}
+.fcopy{font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:0.1em;color:rgba(240,236,226,0.15);margin-top:3rem}
+@media(max-width:768px){nav{top:1rem;right:1rem}.hero{grid-template-columns:1fr}.hdb{grid-column:1;grid-row:1}.hv{grid-column:1;grid-row:2;min-height:30vh}.hiside,.ddiv,.cblock,.cfloat{display:none}.mstrip{margin:2rem 0;transform:rotate(-1deg) scale(1.02)}.loccon{grid-template-columns:1fr}.lbkg{display:none}.arow{grid-template-columns:80px 1fr!important}.arow .agenre{display:none}.s2,.s3,.s4,.s5,.s6{margin-left:0!important}.icard:nth-child(2),.icard:nth-child(3){margin-left:0}.icard{padding:3rem 2rem}.ctasection{padding:10vh 5vw}.ctatext{font-size:clamp(3rem,15vw,6rem)}.footer{flex-direction:column;align-items:flex-start}}
\ No newline at end of file
