+}
+
+/* ─── Cursor follow glow (decorative accent) ─── */
+.cursor-glow {
+  position: fixed;
+  width: 320px;
+  height: 320px;
+  border-radius: 50%;
+  background: radial-gradient(circle, rgba(196,115,79,0.06) 0%, transparent 70%);
+  pointer-events: none;
+  z-index: 0;
+  transition: transform 0.15s ease-out;
+  will-change: transform;
+}
+
+/* ─── Selection color ─── */
+::selection {
+  background-color: #e6d8c9;
+  color: #4e3025;
+}
+
+/* ─── Smooth scrollbar ─── */
+::-webkit-scrollbar {
+  width: 6px;
+}
+
+::-webkit-scrollbar-track {
+  background: #f2ebe3;
+}
+
+::-webkit-scrollbar-thumb {
+  background: #d4bfa6;
+  border-radius: 3px;
+}
+
+::-webkit-scrollbar-thumb:hover {
+  background: #b78762;
+}
