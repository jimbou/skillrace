# Level-2 per-skill base: unit-test-generation (vendored rmyndharis, via skillsmp S5). Stdlib + pytest.
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}
COPY repo/    /workspace/
COPY SKILL.md /skills/unit-test-generation/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: unit-test-generation workspace" || true
