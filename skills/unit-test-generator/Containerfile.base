# Level-2 per-skill base: unit-test-generator (unit-test instance, vendored JackyST0). Stdlib + pytest.
FROM skillrace/skillgen-base:latest
COPY repo/    /workspace/
COPY SKILL.md /skills/unit-test-generator/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: unit-test-generator" || true
