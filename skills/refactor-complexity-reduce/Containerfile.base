# Level-2 per-skill base: refactor-complexity-reduce (refactor instance, vendored github). Stdlib + pytest.
FROM skillrace/skillgen-base:latest
COPY repo/    /workspace/
COPY SKILL.md /skills/refactor-complexity-reduce/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: refactor-complexity-reduce" || true
