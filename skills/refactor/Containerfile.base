# Level-2 per-skill base: refactor (vendored unkeyed, via skillsmp S5). Stdlib + pytest.
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}
COPY repo/    /workspace/
COPY SKILL.md /skills/refactor/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: refactor workspace" || true
