# Level-2 per-skill base: cli-subcommand-validator (cli instance, vendored kjuhwa).
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}

COPY repo/    /workspace/
COPY SKILL.md /skills/cli-subcommand-validator/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: cli-subcommand-validator" || true
