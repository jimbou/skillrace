# Level-2 per-skill base: code-refactor-fowler (refactor instance, vendored luongnv89). Stdlib + pytest.
FROM skillrace/skillgen-base:latest
COPY repo/    /workspace/
COPY SKILL.md /skills/code-refactor-fowler/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: code-refactor-fowler" || true
