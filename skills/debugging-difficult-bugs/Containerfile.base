# Level-2 per-skill base: debugging-difficult-bugs (vendored mastra-ai, via skillsmp S5). Stdlib + pytest.
FROM skillrace/skillgen-base:latest
COPY repo/    /workspace/
COPY SKILL.md /skills/debugging-difficult-bugs/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: debugging-difficult-bugs workspace" || true
