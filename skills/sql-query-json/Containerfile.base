# Level-2 per-skill base: sql-query-json (sql instance, vendored scalyclaw). Stdlib + pytest.
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}
COPY repo/    /workspace/
COPY SKILL.md /skills/sql-query-json/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: sql-query-json" || true
