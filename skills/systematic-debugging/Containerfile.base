# Level-2 per-skill base: systematic-debugging (vendored obra/superpowers). git + python + pytest.
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}
COPY repo/    /workspace/
COPY SKILL.md /skills/systematic-debugging/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: systematic-debugging workspace" || true
