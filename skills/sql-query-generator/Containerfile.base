# Level-2 per-skill base: sql-query-generator (sql instance, vendored phuryn).
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}

COPY repo/    /workspace/
COPY SKILL.md /skills/sql-query-generator/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: sql-query-generator" || true
