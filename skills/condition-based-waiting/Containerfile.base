# Level-2 per-skill base: condition-based-waiting (vendored obra/superpowers). Python + pytest.
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}
COPY repo/ /workspace/
COPY SKILL.md example.ts /skills/condition-based-waiting/
RUN cd /workspace && git add -A && git commit -q -m "base: condition-based-waiting workspace" || true
