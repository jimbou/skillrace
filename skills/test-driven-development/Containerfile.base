# Level-2 per-skill base: test-driven-development. FROM the shared python+pytest base.
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}
COPY repo/    /workspace/
COPY SKILL.md /skills/test-driven-development/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: empty TDD project" || true
