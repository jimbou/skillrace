# Level-2 per-skill base: sql-queries. Portable, stdlib-only (python3 `sqlite3`).
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}
COPY repo/    /workspace/
COPY SKILL.md /skills/sql-queries/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: empty sql workspace" || true
