# Level-2 per-skill base: regex-expert. Portable, stdlib-only (python3 `re`).
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}
COPY repo/    /workspace/
COPY SKILL.md /skills/regex-expert/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: empty regex workspace" || true
