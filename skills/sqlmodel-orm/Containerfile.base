# Level-2 per-skill base: sqlmodel-orm (sql instance, vendored fastapi). NETWORK-GATED build.
FROM skillrace/skillgen-base:latest
RUN apt-get update \
    && apt-get install -y --no-install-recommends python3-pip \
    && rm -rf /var/lib/apt/lists/* \
    && python3 -m pip install --break-system-packages --no-cache-dir sqlmodel==0.0.39
COPY repo/    /workspace/
COPY SKILL.md /skills/sqlmodel-orm/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: sqlmodel-orm" || true
