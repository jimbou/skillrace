# Level-2 per-skill base: cli-argparse-fix (cli instance, vendored cuioss).
ARG SKILLGEN_BASE_IMAGE=skillrace/skillgen-base:0.73.1-construction
FROM ${SKILLGEN_BASE_IMAGE}

COPY repo/    /workspace/
COPY SKILL.md /skills/cli-argparse-fix/SKILL.md
RUN cd /workspace && git add -A && git commit -q -m "base: cli-argparse-fix" || true
